{
  "name": "timestamp-tool-plugin",
  "version": "1.0.0",
  "description": "时间戳转换工具 - 支持时间段/秒/毫秒/纳秒互转",
  "author": {
    "name": "UniHub Team",
    "email": "team@unihub.dev",
    "url": "https://github.com/unihub"
  },
  "keywords": [
    "timestamp",
    "time",
    "unix",
    "converter",
    "timezone",
    "时间戳",
    "时间转换",
    "时间段"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package": "node scripts/package.js"
  },
  "unihub": {
    "id": "com.unihub.timestamp-tool",
    "name": "时间戳转换",
    "icon": "https://api.iconify.design/twemoji/clockwise-vertical-arrows.svg",
    "category": "tool",
    "permissions": [
      "clipboard"
    ],
    "entry": "dist/index.html"
  },
  "dependencies": {
    "lucide-vue-next": "^0.562.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^5.2.1",
    "archiver": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.3"
  }
}
